---
const today = new Date();
---

<footer class="mt-20 border-t border-[var(--border)] bg-[var(--background)] py-12 text-center text-[var(--text-secondary)]">
	<div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8 text-left">
			<div class="col-span-1 md:col-span-1">
				<h4 class="text-lg font-bold text-[var(--text-primary)] mb-4">Emanuele Bartolesi</h4>
				<p class="text-sm">GitHub Technical Lead, Tech Writer and Speaker</p>
				<p class="text-sm mt-2">Sharing knowledge about Azure, .NET, and modern development practices.</p>
			</div>
			
			<div class="col-span-1 md:col-span-1">
				<h4 class="text-lg font-bold text-[var(--text-primary)] mb-4">Links</h4>
				<div class="flex flex-col gap-2 text-sm">
					<a href="/blog" class="hover:text-[var(--accent)] transition-colors">Blog</a>
					<a href="/speaking" class="hover:text-[var(--accent)] transition-colors">Speaking</a>
					<a href="/courses" class="hover:text-[var(--accent)] transition-colors">Courses</a>
					<a href="/about" class="hover:text-[var(--accent)] transition-colors">About Me</a>
				</div>
			</div>
			
