---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// Types for Sessionize API response
interface SessionizeSpeaker {
  firstName: string;
  lastName: string;
  tagline: string;
  bio: string;
  speakerProfileUrl: string;
  photoUrl: string;
  photoLargeUrl: string;
}

interface SessionizeSession {
  id: number;
  title: string;
  description: string;
  sessionUrl: string;
  languageCode: string;
  language: string;
}

interface SessionizeEvent {
  id: number;
  name: string;
  eventStartDate: string; // ISO
  eventEndDate: string;   // ISO
  location: string;
  website: string | null;
  slug: string;
}

interface SessionizeApiResponse {
  speaker: SessionizeSpeaker;
  sessions: SessionizeSession[];
  events: SessionizeEvent[];
}

const endpoint = 'https://sessionize.com/api/speaker/json/h69iuxpcmg';

let data: SessionizeApiResponse | null = null;
let fetchError: string | null = null;

try {
  const res = await fetch(endpoint, {
    headers: {
      'User-Agent': 'Mozilla/5.0 (compatible; SiteBuildBot/1.0; +https://example.com)'
    }
  });
  if (!res.ok) throw new Error(`HTTP ${res.status} ${res.statusText}`);
  data = await res.json();
} catch (err) {
  fetchError = err instanceof Error ? err.message : 'Unknown error';
}

// Helpers
const toDate = (s: string) => new Date(s);

const now = new Date();
const _events = data?.events || [];
const upcomingEvents = _events.filter(e => toDate(e.eventEndDate) >= now)
  .sort((a, b) => toDate(a.eventStartDate).getTime() - toDate(b.eventStartDate).getTime());
const pastEvents = _events.filter(e => toDate(e.eventEndDate) < now)
  .sort((a, b) => toDate(b.eventStartDate).getTime() - toDate(a.eventStartDate).getTime()); // descending

// Extract simple technology tags from titles/descriptions
const techKeywords = ['Azure', 'GitHub', 'DevOps', 'CI/CD', 'Docker', 'Kubernetes', 'C#', '.NET', 'React', 'Node.js', 'AI', 'Cloud', 'Microservices', 'Blazor', 'ASP.NET', 'TypeScript', 'JavaScript'];
const techSet = new Set<string>();

const sessionsByLanguage: Record<string, SessionizeSession[]> = {};

data?.sessions?.forEach(s => {
  techKeywords.forEach(k => {
    if (s.title.toLowerCase().includes(k.toLowerCase()) || 
        (s.description && s.description.toLowerCase().includes(k.toLowerCase()))) {
      techSet.add(k);
    }
  });

  if (!sessionsByLanguage[s.language]) {
    sessionsByLanguage[s.language] = [];
  }
  sessionsByLanguage[s.language].push(s);
});

const technologies = Array.from(techSet).sort((a, b) => a.localeCompare(b));

const fmtDate = (iso: string) => {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Speaking - My Tech Talks and Events" description="Public speaking, conferences, and technical sessions." />
	</head>
	<body class="bg-[var(--background)] text-[var(--text-primary)] font-body antialiased min-h-screen flex flex-col selection:bg-[var(--accent)] selection:text-white">
		<Header />
		<main class="flex-grow w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			
			<div class="text-center mb-16 relative">
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[var(--accent)]/10 blur-[100px] rounded-full pointer-events-none"></div>
				
				<span class="inline-block text-5xl mb-4 relative z-10">🎤</span>
				<h1 class="text-5xl md:text-7xl font-black tracking-tighter text-[var(--text-primary)] mb-6 relative z-10">
					Tech <span class="text-[var(--accent)]">Speaking</span>
				</h1>
			</div>

			<div class="prose prose-lg dark:prose-invert max-w-3xl mx-auto text-center mb-20">
				<p class="text-[var(--text-secondary)] text-xl font-medium leading-relaxed">
					I regularly speak at conferences, meetups, and online events about Azure, Microsoft 365, DevOps, CI/CD, GitHub, and other technical topics. Here you can find a list of my past and upcoming speaking engagements.
				</p>
				<div class="mt-8 p-8 bg-[var(--background-secondary)]/30 border border-[var(--border)] rounded-3xl backdrop-blur-sm">
					<h2 class="text-2xl font-black text-[var(--text-primary)] mb-4">Want me to speak at your event?</h2>
					<p class="text-[var(--text-secondary)] mb-6">
						If you'd like me to speak at your event, please reach out via my social channels or LinkedIn. You can also check out my <a href="https://sessionize.com/emanuelebartolesi/" target="_blank" class="text-[var(--accent)] hover:underline font-bold">Sessionize profile</a>.
					</p>
					<a href="https://sessionize.com/emanuelebartolesi/" target="_blank" class="inline-flex items-center justify-center px-6 py-3 font-bold text-[var(--background)] bg-[var(--text-primary)] hover:bg-[var(--accent)] hover:text-white rounded-full transition-colors shadow-lg">
						View Speaker Profile
					</a>
				</div>
			</div>

			{fetchError ? (
				<div class="bg-red-500/10 border-2 border-red-500/50 text-red-500 p-8 rounded-3xl text-center shadow-lg">
					<span class="text-4xl mb-4 block">❌</span>
					<h2 class="text-2xl font-black mb-2">Unable to load speaking data</h2>
					<p class="font-mono text-sm opacity-80 mb-2">Error: {fetchError}</p>
					<p>Please try again later.</p>
				</div>
			) : !data ? (
				<div class="bg-[var(--background-secondary)]/20 border border-[var(--border)] p-12 rounded-3xl text-center shadow-lg animate-pulse">
					<span class="text-4xl mb-4 block animate-bounce">⏳</span>
					<h2 class="text-2xl font-black text-[var(--text-primary)] mb-2">Loading...</h2>
					<p class="text-[var(--text-secondary)]">Fetching the latest information from Sessionize.</p>
				</div>
			) : (
				<div class="space-y-24">
					
					{/* Upcoming Events */}
					<section>
						<div class="flex items-center gap-4 mb-8 border-b border-[var(--border)] pb-4">
							<span class="text-3xl">🚀</span>
							<div>
								<h2 class="text-3xl font-black text-[var(--text-primary)] tracking-tight">Upcoming Events</h2>
								<p class="text-[var(--text-secondary)]">Where you can catch me next</p>
							</div>
						</div>

						{upcomingEvents.length === 0 ? (
							<div class="bg-[var(--background-secondary)]/20 border border-dashed border-[var(--border)] p-12 rounded-3xl text-center">
								<span class="text-3xl block mb-2 opacity-50">📅</span>
								<p class="text-[var(--text-secondary)] font-medium">No upcoming events listed right now.</p>
							</div>
						) : (
							<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
								{upcomingEvents.map(e => (
									<div class="group relative flex flex-col bg-[var(--background-secondary)]/30 border-2 border-[var(--accent)]/30 rounded-3xl p-6 hover:border-[var(--accent)] transition-all duration-300 shadow-lg shadow-[var(--accent)]/5 hover:-translate-y-1">
										<div class="absolute -top-3 -right-3 px-4 py-1.5 bg-gradient-to-r from-[var(--accent)] to-purple-500 text-white text-xs font-black uppercase tracking-widest rounded-full shadow-lg rotate-3 group-hover:rotate-6 transition-transform">
											Upcoming
										</div>
										
										<div class="flex items-start gap-4 mb-4">
											<div class="w-12 h-12 rounded-xl bg-[var(--background-tertiary)] flex items-center justify-center text-xl flex-shrink-0 shadow-inner group-hover:bg-[var(--accent)]/20 group-hover:scale-110 transition-all">🎯</div>
											<h3 class="text-xl font-bold leading-tight text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">
												{e.name}
											</h3>
										</div>
										
										<div class="space-y-3 mb-6 font-medium text-sm text-[var(--text-secondary)] flex-grow">
											<div class="flex items-center gap-3">
												<span class="opacity-50">📅</span>
												<span>{fmtDate(e.eventStartDate)} – {fmtDate(e.eventEndDate)}</span>
											</div>
											{e.location && (
												<div class="flex items-center gap-3">
													<span class="opacity-50">📍</span>
													<span>{e.location}</span>
												</div>
											)}
										</div>
										
										{e.website && (
											<a href={e.website} target="_blank" rel="noopener noreferrer" class="mt-auto block w-full py-2.5 px-4 text-center font-bold text-sm text-[var(--text-primary)] bg-[var(--background-tertiary)] hover:bg-[var(--accent)] hover:text-white rounded-xl transition-colors border border-[var(--border)] group-hover:border-transparent">
												Visit Website
											</a>
										)}
									</div>
								))}
							</div>
						)}
					</section>

					{/* Past Events */}
					<section>
						<div class="flex items-center gap-4 mb-8 border-b border-[var(--border)] pb-4 opacity-80">
							<span class="text-3xl grayscale">📚</span>
							<div>
								<h2 class="text-3xl font-black text-[var(--text-primary)] tracking-tight">Past Events</h2>
								<p class="text-[var(--text-secondary)]">A selection of previous conferences and meetups</p>
							</div>
						</div>

						{pastEvents.length === 0 ? (
							<div class="bg-[var(--background-secondary)]/20 border border-dashed border-[var(--border)] p-8 rounded-3xl text-center">
								<p class="text-[var(--text-secondary)]">No past events listed.</p>
							</div>
						) : (
							<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
								{pastEvents.slice(0, 12).map(e => (
									<div class="group flex flex-col bg-[var(--background-secondary)]/10 border border-[var(--border)] rounded-2xl p-5 hover:border-[var(--text-secondary)] transition-colors">
										<div class="mb-3">
											<span class="inline-block px-2 py-1 bg-[var(--background-tertiary)] text-[var(--text-secondary)] text-[10px] font-bold uppercase tracking-wider rounded border border-[var(--border)] mb-3 opacity-70">
												Completed
											</span>
											<h4 class="text-lg font-bold leading-tight text-[var(--text-primary)] group-hover:text-[var(--text-primary)] line-clamp-2">
												{e.name}
											</h4>
										</div>
										
										<div class="space-y-2 mb-4 text-xs font-medium text-[var(--text-secondary)] flex-grow font-mono">
											<div class="flex items-center gap-2">
												<span>•</span>
												<span>{fmtDate(e.eventStartDate)}</span>
											</div>
											{e.location && (
												<div class="flex items-center gap-2">
													<span>•</span>
													<span class="truncate">{e.location}</span>
												</div>
											)}
										</div>
										
										{e.website && (
											<a href={e.website} target="_blank" rel="noopener noreferrer" class="text-sm font-bold text-[var(--text-secondary)] hover:text-[var(--accent)] hover:underline inline-flex items-center gap-1 mt-auto">
												Website <span>↗</span>
											</a>
										)}
									</div>
								))}
							</div>
						)}
					</section>

					{/* Technologies & Topics */}
					{technologies.length > 0 && (
						<section>
							<div class="flex items-center gap-4 mb-8 border-b border-[var(--border)] pb-4 relative z-10">
								<span class="text-3xl">🛠️</span>
								<div>
									<h2 class="text-3xl font-black text-[var(--text-primary)] tracking-tight">Technologies & Topics</h2>
									<p class="text-[var(--text-secondary)]">Keywords extracted from session titles and descriptions</p>
								</div>
							</div>
							<div class="flex flex-wrap gap-3 relative z-10">
								{technologies.map(t => (
									<span class="px-4 py-2 bg-[var(--background-secondary)]/30 border border-[var(--border)] text-[var(--text-primary)] text-sm font-bold rounded-full shadow-sm hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors cursor-default">
										{t}
									</span>
								))}
							</div>
						</section>
					)}

					{/* Available Sessions */}
					{data.sessions && data.sessions.length > 0 && (
						<section>
							<div class="flex items-center gap-4 mb-8 border-b border-[var(--border)] pb-4 relative z-10">
								<span class="text-3xl">💼</span>
								<div>
									<h2 class="text-3xl font-black text-[var(--text-primary)] tracking-tight">Available Sessions</h2>
									<p class="text-[var(--text-secondary)]">Talks ready for conferences, meetups, and corporate events</p>
								</div>
							</div>
							<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 relative z-10">
								{data.sessions.map(s => (
									<div class="group flex flex-col bg-[var(--background-secondary)]/10 border border-[var(--border)] rounded-2xl p-6 hover:border-[var(--accent)] hover:shadow-lg transition-all duration-300 relative overflow-hidden">
										<div class="absolute top-0 right-0 px-3 py-1 bg-[var(--background-tertiary)] border-b border-l border-[var(--border)] text-xs font-bold text-[var(--text-secondary)] rounded-bl-xl">
											🌐 {s.language}
										</div>
										<h3 class="text-xl font-bold leading-tight text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors pr-16 mb-4">
											{s.title}
										</h3>
										{s.description && (
											<p class="text-sm text-[var(--text-secondary)] mb-6 line-clamp-4 leading-relaxed flex-grow">
												{s.description}
											</p>
										)}
										<div class="mt-auto pt-4 border-t border-[var(--border)]/50">
											<a href={s.sessionUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-bold text-[var(--text-primary)] hover:text-[var(--accent)] transition-colors">
												View Session Details <span>→</span>
											</a>
										</div>
									</div>
								))}
							</div>
						</section>
					)}

				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
