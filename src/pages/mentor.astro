---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Professional Mentoring Services" description="Expert mentoring in web development, cloud technologies, and career growth. Book 1:1 sessions with Microsoft MVP Emanuele Bartolesi." />
	</head>
	<body class="bg-[var(--background)] text-[var(--text-primary)] font-body antialiased min-h-screen flex flex-col selection:bg-[var(--accent)] selection:text-white">
		<Header />
		<main class="flex-grow w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			
			<!-- Hero Section -->
			<section class="text-center mb-20 relative">
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-blue-500/10 blur-[100px] rounded-full pointer-events-none"></div>
				
				<div class="inline-flex items-center justify-center p-3 mb-6 bg-blue-500/10 text-blue-500 rounded-2xl shadow-inner shrink-0 rotate-3 transition-transform hover:rotate-6">
					<span class="text-4xl leading-none">🤝</span>
				</div>
				
				<h1 class="text-5xl md:text-7xl font-black tracking-tighter text-[var(--text-primary)] mb-6 relative z-10">
					Professional <span class="text-[var(--accent)]">Mentoring</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-[var(--text-secondary)] font-medium max-w-2xl mx-auto relative z-10 mb-10 leading-relaxed">
					Accelerate your career in web development, cloud technologies, and AI/ML with personalized guidance from someone with 20+ years of experience.
				</p>
				
				<div class="relative z-10">
					<a href="https://mentors.to/emanuelebartolesi" target="_blank" rel="noopener" class="inline-flex items-center justify-center px-8 py-4 font-bold bg-[var(--accent)] hover:opacity-90 rounded-full transition-all shadow-xl shadow-[var(--accent)]/20 hover:-translate-y-1 gap-2 group text-lg" style="color: #ffffff;">
						Book a Session 
						<span class="group-hover:translate-x-1 transition-transform" style="color: #ffffff;">→</span>
					</a>
				</div>
			</section>

			<!-- Statistics -->
			<section class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-24 relative z-10">
				<div class="bg-[var(--background-secondary)]/40 backdrop-blur-sm border border-[var(--border)] rounded-3xl p-6 text-center shadow-lg">
					<div class="text-4xl md:text-5xl font-black text-blue-500 mb-2">100+</div>
					<div class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Mentoring Sessions</div>
				</div>
				<div class="bg-[var(--background-secondary)]/40 backdrop-blur-sm border border-[var(--border)] rounded-3xl p-6 text-center shadow-lg">
					<div class="text-4xl md:text-5xl font-black text-blue-500 mb-2">55+</div>
					<div class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Happy Mentees</div>
				</div>
				<div class="bg-[var(--background-secondary)]/40 backdrop-blur-sm border border-[var(--border)] rounded-3xl p-6 text-center shadow-lg">
					<div class="text-4xl md:text-5xl font-black text-blue-500 mb-2">20+</div>
					<div class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Years Experience</div>
				</div>
				<div class="bg-[var(--background-secondary)]/40 backdrop-blur-sm border border-[var(--border)] rounded-3xl p-6 text-center shadow-lg">
					<div class="text-4xl md:text-5xl font-black text-blue-500 mb-2">4.9</div>
					<div class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Average Rating</div>
				</div>
			</section>

			<!-- Areas of Expertise -->
			<section class="mb-24 relative z-10">
				<h2 class="text-3xl font-black tracking-tight text-[var(--text-primary)] mb-8 flex items-center justify-center gap-3">
					<span class="text-blue-500">🎯</span> Areas of Expertise
				</h2>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
					<!-- Web Development -->
					<div class="group bg-[var(--background-secondary)]/20 border border-[var(--border)] rounded-3xl p-8 hover:border-blue-500/50 transition-all duration-300 hover:shadow-xl hover:shadow-blue-500/5">
						<div class="w-14 h-14 bg-blue-500/10 text-blue-500 rounded-2xl flex items-center justify-center text-3xl mb-6 shadow-inner group-hover:scale-110 transition-transform">🌐</div>
						<h3 class="text-2xl font-bold text-[var(--text-primary)] mb-3">Web Development</h3>
						<p class="text-[var(--text-secondary)] mb-6 leading-relaxed">
							Modern .NET applications, React frontends, and TypeScript development
						</p>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">.NET</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">React</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">TypeScript</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Next.js</span>
						</div>
					</div>

					<!-- Cloud Architecture -->
					<div class="group bg-[var(--background-secondary)]/20 border border-[var(--border)] rounded-3xl p-8 hover:border-cyan-500/50 transition-all duration-300 hover:shadow-xl hover:shadow-cyan-500/5">
						<div class="w-14 h-14 bg-cyan-500/10 text-cyan-500 rounded-2xl flex items-center justify-center text-3xl mb-6 shadow-inner group-hover:scale-110 transition-transform">☁️</div>
						<h3 class="text-2xl font-bold text-[var(--text-primary)] mb-3">Cloud Architecture</h3>
						<p class="text-[var(--text-secondary)] mb-6 leading-relaxed">
							Azure solutions, scalable architectures, and serverless applications
						</p>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Azure</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Microservices</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Serverless</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Architecture</span>
						</div>
					</div>

					<!-- AI & Machine Learning -->
					<div class="group bg-[var(--background-secondary)]/20 border border-[var(--border)] rounded-3xl p-8 hover:border-purple-500/50 transition-all duration-300 hover:shadow-xl hover:shadow-purple-500/5">
						<div class="w-14 h-14 bg-purple-500/10 text-purple-500 rounded-2xl flex items-center justify-center text-3xl mb-6 shadow-inner group-hover:scale-110 transition-transform">🤖</div>
						<h3 class="text-2xl font-bold text-[var(--text-primary)] mb-3">AI Integration</h3>
						<p class="text-[var(--text-secondary)] mb-6 leading-relaxed">
							Integrating AI into modern applications, Semantic Kernel, and Prompt Engineering
						</p>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">OpenAI</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Semantic Kernel</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Copilot</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">LLMs</span>
						</div>
					</div>

					<!-- Career Growth -->
					<div class="group bg-[var(--background-secondary)]/20 border border-[var(--border)] rounded-3xl p-8 hover:border-green-500/50 transition-all duration-300 hover:shadow-xl hover:shadow-green-500/5">
						<div class="w-14 h-14 bg-green-500/10 text-green-500 rounded-2xl flex items-center justify-center text-3xl mb-6 shadow-inner group-hover:scale-110 transition-transform">📈</div>
						<h3 class="text-2xl font-bold text-[var(--text-primary)] mb-3">Career Growth</h3>
						<p class="text-[var(--text-secondary)] mb-6 leading-relaxed">
							Resume reviews, interview preparation, and developer relations strategies
						</p>
						<div class="flex flex-wrap gap-2">
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">DevRel</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Public Speaking</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Personal Branding</span>
							<span class="px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] text-[var(--text-secondary)] text-xs font-bold uppercase tracking-wider rounded-lg">Leadership</span>
						</div>
					</div>
				</div>
			</section>

			<!-- Expectations and Testimonials -->
			<section class="max-w-3xl mx-auto space-y-12 mb-16 relative z-10">
				
				<div class="bg-[var(--background-secondary)]/30 border border-[var(--border)] rounded-3xl p-8 md:p-12">
					<h2 class="text-2xl font-black text-[var(--text-primary)] mb-6 flex items-center gap-3">
						<span class="text-xl">💡</span> What to Expect
					</h2>
					<ul class="space-y-4 text-[var(--text-secondary)]">
						<li class="flex items-start gap-3">
							<svg class="w-6 h-6 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
							<span>Personalized advice tailored to your specific goals and context</span>
						</li>
						<li class="flex items-start gap-3">
							<svg class="w-6 h-6 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
							<span>Honest, constructive feedback on your code, architecture, or career trajectory</span>
						</li>
						<li class="flex items-start gap-3">
							<svg class="w-6 h-6 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
							<span>Actionable next steps after every session to keep your momentum</span>
						</li>
						<li class="flex items-start gap-3">
							<svg class="w-6 h-6 text-blue-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
							<span>Direct insights drawn from 20+ years navigating the tech industry</span>
						</li>
					</ul>
				</div>
				
			</section>

		</main>
		<Footer />
	</body>
</html>
