---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';
import { 
  courses, 
  getFeaturedCourses, 
  courseCategories, 
  getCourseStats 
} from '../data/courses';

const featuredCourses = getFeaturedCourses();
const allCourses = courses.filter(course => course.available);
const stats = getCourseStats();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Courses - Professional Training" description="Professional development courses and training programs. Learn modern web development, AI integration, and cloud deployment." />
	</head>
	<body class="bg-[var(--background)] text-[var(--text-primary)] font-body antialiased min-h-screen flex flex-col selection:bg-[var(--accent)] selection:text-white">
		<Header />
		
		<main class="flex-grow w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			<!-- Header Section -->
			<section class="text-center mb-16 relative">
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[var(--accent)]/10 blur-[100px] rounded-full pointer-events-none"></div>
				
				<h1 class="text-5xl md:text-7xl font-black tracking-tighter text-[var(--text-primary)] mb-6 relative z-10">
					Professional <span class="text-[var(--accent)]">Training</span>
				</h1>
				<p class="text-xl md:text-2xl text-[var(--text-secondary)] font-medium max-w-2xl mx-auto relative z-10 mb-8">
					Level up your skills with comprehensive courses on cloud deployment, web development, and AI integration.
				</p>
				
				{/* Stats Cards */}
				<div class="flex justify-center gap-4 sm:gap-8 flex-wrap">
					<div class="flex flex-col items-center justify-center p-4 bg-[var(--background-secondary)]/50 border border-[var(--border)] rounded-2xl w-32 shadow-sm relative overflow-hidden group">
						<span class="text-2xl mb-1">📚</span>
						<span class="text-3xl font-black text-[var(--text-primary)] mb-1">{stats.totalCourses}</span>
						<span class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Courses</span>
					</div>
					<div class="flex flex-col items-center justify-center p-4 bg-[var(--background-secondary)]/50 border border-[var(--border)] rounded-2xl w-32 shadow-sm relative overflow-hidden group">
						<span class="text-2xl mb-1">⏱️</span>
						<span class="text-3xl font-black text-[var(--text-primary)] mb-1">11h+</span>
						<span class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Content</span>
					</div>
					<div class="flex flex-col items-center justify-center p-4 bg-[var(--background-secondary)]/50 border border-[var(--border)] rounded-2xl w-32 shadow-sm relative overflow-hidden group">
						<span class="text-2xl mb-1">🧑‍🎓</span>
						<span class="text-3xl font-black text-[var(--text-primary)] mb-1">1k+</span>
						<span class="text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]">Students</span>
					</div>
				</div>
			</section>

			<!-- Categories Filter Area (Visual Only) -->
			<div class="flex flex-wrap justify-center gap-2 mb-12">
				{courseCategories.map((category: any) => (
					<div class:list={[
						"px-4 py-2 rounded-full text-sm transition-colors cursor-pointer",
						category.key === 'all' 
							? "bg-[var(--text-primary)] text-[var(--background)] font-bold shadow-md"
							: "bg-[var(--background-secondary)] text-[var(--text-secondary)] hover:text-[var(--text-primary)] border border-[var(--border)] font-medium"
					]}>
						{category.label}
					</div>
				))}
			</div>

			<!-- Featured Courses -->
			{featuredCourses.length > 0 && (
				<section class="mb-20">
					<h2 class="text-3xl font-black tracking-tight text-[var(--text-primary)] mb-8 flex items-center gap-3">
						<span class="text-yellow-500">⭐</span> Featured Programs
					</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						{featuredCourses.map((course: any) => (
							<div class="group flex flex-col bg-[var(--background-secondary)]/30 border-2 border-[var(--accent)]/50 rounded-3xl overflow-hidden hover:border-[var(--accent)] transition-all duration-300 shadow-xl shadow-[var(--accent)]/5 relative">
								<div class="absolute top-4 right-4 z-10 px-3 py-1 bg-[var(--background)] text-[var(--accent)] text-xs font-bold uppercase tracking-wider rounded-full border border-[var(--accent)] shadow-sm">
									Featured
								</div>
								
								<div class="h-48 md:h-56 relative overflow-hidden bg-gradient-to-br from-[var(--background-secondary)] to-[var(--background-tertiary)] flex items-center justify-center">
									{course.imageUrl ? (
										<img src={course.imageUrl} alt={course.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
									) : (
										<div class="text-[var(--text-secondary)] opacity-30 font-black text-6xl">COURSE</div>
									)}
								</div>
								
								<div class="p-6 md:p-8 flex flex-col flex-grow">
									<div class="flex justify-between items-start mb-4 gap-4">
										<h3 class="text-2xl font-bold leading-tight text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors">
											{course.title}
										</h3>
										<div class="flex-shrink-0 text-right">
											{course.price && (course.price.individual || course.price.corporate) ? (
												<div class="text-xl font-black text-[var(--text-primary)]">
													{course.price.currency === 'USD' ? '$' : course.price.currency}{course.price.individual || course.price.corporate}
												</div>
											) : (
												<div class="text-lg font-bold text-green-500 uppercase tracking-wider">Free</div>
											)}
										</div>
									</div>
									
									<p class="text-[var(--text-secondary)] mb-6 line-clamp-2">
										{course.description}
									</p>
									
									<div class="flex flex-wrap gap-2 mb-6">
										{course.tags && course.tags.slice(0, 3).map((tag: string) => (
											<span class="px-2 py-1 text-xs font-bold uppercase tracking-wider bg-[var(--background-tertiary)] text-[var(--text-secondary)] rounded-md border border-[var(--border)]">
												{tag}
											</span>
										))}
									</div>
									
									<div class="mt-auto grid grid-cols-2 gap-4 text-sm font-medium text-[var(--text-secondary)] mb-6 pb-6 border-b border-[var(--border)]">
										<div class="flex items-center gap-2">
											<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
											{course.duration || 'Self-paced'}
										</div>
										<div class="flex items-center gap-2 text-right justify-end">
											<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
											{course.level || 'All levels'}
										</div>
									</div>
									
									<a href={course.link || '#'} class="block w-full py-3 px-4 text-center font-bold text-[var(--background)] bg-[var(--text-primary)] hover:bg-[var(--accent)] hover:text-white rounded-xl transition-colors">
										Enroll Now
									</a>
								</div>
							</div>
						))}
					</div>
				</section>
			)}

			<!-- All Courses List -->
			<section>
				<h2 class="text-3xl font-black tracking-tight text-[var(--text-primary)] mb-8">
					Explore Catalog
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{allCourses.filter(c => !featuredCourses.find(fc => fc.id === c.id)).map((course: any) => (
						<div class="group flex flex-col bg-[var(--background-secondary)]/20 border border-[var(--border)] rounded-2xl overflow-hidden hover:border-[var(--border-light)] transition-all duration-300 hover:shadow-lg hover:-translate-y-1 relative">
							{course.upcoming && (
								<div class="absolute top-3 left-3 z-10 px-2 py-1 bg-[var(--background-tertiary)]/80 backdrop-blur text-[var(--text-primary)] text-[10px] font-bold uppercase tracking-wider rounded border border-[var(--border)]">
									Upcoming
								</div>
							)}
							
							<div class="h-40 relative overflow-hidden bg-gradient-to-br from-[var(--background-secondary)] to-[var(--background-tertiary)] flex items-center justify-center">
								{course.imageUrl ? (
									<img src={course.imageUrl} alt={course.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
								) : (
									<div class="text-[var(--text-secondary)] opacity-30 font-black text-2xl">COURSE</div>
								)}
							</div>
							
							<div class="p-5 flex flex-col flex-grow">
								<h3 class="text-xl font-bold leading-tight text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors mb-2 line-clamp-2">
									{course.title}
								</h3>
								
								<p class="text-sm text-[var(--text-secondary)] mb-4 line-clamp-2">
									{course.description}
								</p>
								
								<div class="mt-auto flex items-center justify-between pt-4 border-t border-[var(--border)]">
									<div class="text-sm font-medium text-[var(--text-secondary)]">
										{course.duration || 'Self-paced'}
									</div>
									<div class="font-bold text-[var(--text-primary)]">
										{course.price && (course.price.individual || course.price.corporate) ? 
											`${course.price.currency === 'USD' ? '$' : course.price.currency}${course.price.individual || course.price.corporate}` 
											: <span class="text-green-500">Free</span>}
									</div>
								</div>
								
								<a href={course.link || '#'} class="mt-4 block w-full py-2 px-4 text-center text-sm font-bold text-[var(--text-primary)] bg-[var(--background-tertiary)] hover:bg-[var(--accent)] hover:text-white rounded-lg transition-colors">
									{course.upcoming ? 'Notify Me' : 'View Details'}
								</a>
							</div>
						</div>
					))}
				</div>
			</section>

		</main>

		<Footer />
	</body>
</html>