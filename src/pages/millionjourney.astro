---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TheMillionJourney from "../components/TheMillionJourney.astro";

const title = "The Million Journey";
const description = "Follow my journey to reach one million in revenue, subscribers, or impact. Track progress, milestones, and lessons learned along the way.";
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body class="bg-[var(--background)] text-[var(--text-primary)] font-body antialiased min-h-screen flex flex-col selection:bg-[var(--accent)] selection:text-white">
		<Header />
		<main class="flex-grow w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			<div class="text-center mb-16 relative">
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[var(--accent)]/10 blur-[100px] rounded-full pointer-events-none"></div>
				
				<span class="inline-block text-5xl mb-4 relative z-10">💸</span>
				<h1 class="text-5xl md:text-7xl font-black tracking-tighter text-[var(--text-primary)] mb-6 relative z-10">
					The Million <span class="text-[var(--accent)]">Journey</span>
				</h1>
				<p class="text-xl md:text-2xl text-[var(--text-secondary)] font-medium max-w-2xl mx-auto relative z-10 mb-4 leading-relaxed">
					Each square represents $1,000 towards my million-dollar goal.
				</p>
				<p class="text-[var(--text-secondary)] font-medium max-w-2xl mx-auto relative z-10 opacity-80">
					Track my journey to reach one million in revenue through SaaS, courses, consulting, and more.
				</p>
			</div>
			
			<div class="relative z-10">
				<TheMillionJourney />
			</div>
		</main>
		<Footer />
	</body>
</html>
