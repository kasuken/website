---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Live Streaming - Emanuele Bartolesi" description="Join me on Twitch every Monday and Wednesday for live coding sessions, tech discussions, and programming tutorials." />
	</head>
	<body class="bg-[var(--background)] text-[var(--text-primary)] font-body antialiased min-h-screen flex flex-col selection:bg-[var(--accent)] selection:text-white">
		<Header />
		<main class="flex-grow w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			
			<!-- Header Section -->
			<section class="text-center mb-16 relative">
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-[#9146ff]/10 blur-[100px] rounded-full pointer-events-none"></div>
				
				<div class="inline-flex items-center justify-center p-3 mb-6 bg-[#9146ff]/10 text-[#9146ff] rounded-2xl shadow-inner shrink-0 rotate-3 transition-transform hover:rotate-6">
					<span class="text-4xl leading-none">🔴</span>
				</div>
				
				<h1 class="text-5xl md:text-7xl font-black tracking-tighter text-[var(--text-primary)] mb-6 relative z-10">
					Live <span class="text-[var(--accent)]">Streaming</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-[var(--text-secondary)] font-medium max-w-2xl mx-auto relative z-10 mb-10 leading-relaxed">
					Join me on Twitch for live coding sessions, tech discussions, and programming tutorials.
				</p>

				<a href="https://twitch.tv/kasuken" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-8 py-4 font-bold text-white bg-[#9146ff] hover:bg-[#772ce8] rounded-full transition-all shadow-xl shadow-[#9146ff]/20 hover:scale-105 group relative z-10">
					<svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714Z"/></svg>
					Follow on Twitch
				</a>
			</section>

			<!-- Twitch Embed -->
			<section class="mb-24 relative z-10">
				<div class="aspect-video w-full rounded-3xl overflow-hidden border-2 border-[var(--border)] bg-[#18181b] shadow-2xl shadow-[#9146ff]/5 flex items-center justify-center p-1 relative">
					<div class="absolute inset-0 bg-gradient-to-tr from-[#9146ff]/20 to-transparent pointer-events-none mix-blend-overlay"></div>
					<iframe
						src="https://player.twitch.tv/?channel=kasuken&parent=localhost&parent=127.0.0.1&parent=kasuken.github.io&autoplay=false"
						frameborder="0"
						allowfullscreen="true"
						scrolling="no"
						class="w-full h-full rounded-2xl relative z-10"
					></iframe>
				</div>
			</section>

			<!-- Schedule Section -->
			<section class="max-w-4xl mx-auto mb-24 relative z-10">
				<h2 class="text-3xl font-black tracking-tight text-[var(--text-primary)] mb-8 flex items-center justify-center md:justify-start gap-3">
					<span class="text-2xl">📅</span> Streaming Schedule
				</h2>
				
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<!-- Day 1 -->
					<div class="group bg-[var(--background-secondary)]/30 border border-[var(--border)] rounded-3xl p-8 hover:border-[var(--accent)]/50 transition-all duration-300 relative shadow-xl shadow-[var(--accent)]/5">
						<div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[var(--accent)]/10 to-transparent rounded-bl-full pointer-events-none opacity-50"></div>
						
						<h3 class="text-2xl font-black text-[var(--text-primary)] mb-2">Monday</h3>
						<div class="inline-flex items-center gap-2 px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] rounded-full text-sm font-bold font-mono text-[var(--text-secondary)] mb-4">
							<svg class="w-4 h-4 text-[var(--accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
							10:00 AM - 12:00 PM CET
						</div>
						
						<p class="text-[var(--text-secondary)] leading-relaxed">
							Weekly coding sessions focusing on cloud technologies, .NET development, and DevOps practices.
						</p>
					</div>

					<!-- Day 2 -->
					<div class="group bg-[var(--background-secondary)]/30 border border-[var(--border)] rounded-3xl p-8 hover:border-[var(--accent)]/50 transition-all duration-300 relative shadow-xl shadow-[var(--accent)]/5">
						<div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[#9146ff]/10 to-transparent rounded-bl-full pointer-events-none opacity-50"></div>
						
						<h3 class="text-2xl font-black text-[var(--text-primary)] mb-2">Wednesday</h3>
						<div class="inline-flex items-center gap-2 px-3 py-1 bg-[var(--background-tertiary)] border border-[var(--border)] rounded-full text-sm font-bold font-mono text-[var(--text-secondary)] mb-4">
							<svg class="w-4 h-4 text-[#9146ff]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
							2:00 PM - 4:00 PM CET
						</div>
						
						<p class="text-[var(--text-secondary)] leading-relaxed">
							Interactive Q&A, open source contributions, portfolio reviews, and exploring modern frontend setups (React, Next.js).
						</p>
					</div>
				</div>
				<p class="text-center text-sm font-medium text-[var(--text-secondary)] mt-6 bg-[var(--background-secondary)]/50 border border-[var(--border)] py-3 px-6 rounded-full inline-block mx-auto max-w-fit flex items-center justify-center gap-2">
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
					Schedule is subject to change. Make sure to follow on Twitch to get notified!
				</p>
			</section>

			<!-- Features / What to expect -->
			<section class="max-w-4xl mx-auto relative z-10">
				<h2 class="text-3xl font-black tracking-tight text-[var(--text-primary)] mb-8 flex items-center justify-center md:justify-start gap-3">
					<span class="text-2xl">💡</span> What to Expect
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					<!-- Expectation 1 -->
					<div class="bg-[var(--background-secondary)]/20 p-6 rounded-2xl border border-[var(--border)] shadow-sm">
						<div class="w-12 h-12 rounded-xl bg-[var(--accent)]/10 text-[var(--accent)] flex items-center justify-center text-xl mb-4 font-bold border border-[var(--accent)]/20">
							💻
						</div>
						<h4 class="text-xl font-bold text-[var(--text-primary)] mb-2">Live Coding</h4>
						<p class="text-sm text-[var(--text-secondary)]">Watch real-world problem-solving in action. No edits, just raw development.</p>
					</div>
					<!-- Expectation 2 -->
					<div class="bg-[var(--background-secondary)]/20 p-6 rounded-2xl border border-[var(--border)] shadow-sm">
						<div class="w-12 h-12 rounded-xl bg-orange-500/10 text-orange-500 flex items-center justify-center text-xl mb-4 font-bold border border-orange-500/20">
							💬
						</div>
						<h4 class="text-xl font-bold text-[var(--text-primary)] mb-2">Interactive Q&A</h4>
						<p class="text-sm text-[var(--text-secondary)]">Ask questions anytime in chat. We tackle concepts and roadblocks together.</p>
					</div>
					<!-- Expectation 3 -->
					<div class="bg-[var(--background-secondary)]/20 p-6 rounded-2xl border border-[var(--border)] shadow-sm">
						<div class="w-12 h-12 rounded-xl bg-green-500/10 text-green-500 flex items-center justify-center text-xl mb-4 font-bold border border-green-500/20">
							🚀
						</div>
						<h4 class="text-xl font-bold text-[var(--text-primary)] mb-2">Tech Reviews</h4>
						<p class="text-sm text-[var(--text-secondary)]">Exploring the latest in .NET, Astro, React, and Azure environments.</p>
					</div>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>
