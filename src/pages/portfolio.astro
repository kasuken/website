---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { projects } from '../data/projects';
import GitHubActivityCalendar from '../components/GitHubActivityCalendar.astro';
import GitHubStats from '../components/GitHubStats.astro';

const featuredProjects = projects.filter(project => project.featured);
const allProjects = projects.filter(project => !project.featured);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Portfolio - My Projects" description="Showcase of my development projects, GitHub repositories, and technical work." />
	</head>
	<body class="bg-[var(--background)] text-[var(--text-primary)] font-body antialiased min-h-screen flex flex-col selection:bg-[var(--accent)] selection:text-white">
		<Header />
		<main class="flex-grow w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			
			<section class="text-center mb-16 relative">
				<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-purple-500/10 blur-[100px] rounded-full pointer-events-none"></div>
				
				<h1 class="text-5xl md:text-7xl font-black tracking-tighter text-[var(--text-primary)] mb-6 relative z-10">
					My <span class="text-[var(--accent)]">Portfolio</span>
				</h1>
				<p class="text-xl md:text-2xl text-[var(--text-secondary)] font-medium max-w-2xl mx-auto relative z-10">
					A showcase of my recent work, open-source contributions, and side projects.
				</p>
			</section>

			<!-- Featured Projects -->
			<section class="mb-24">
				<h2 class="text-3xl font-black tracking-tight text-[var(--text-primary)] mb-8 flex items-center gap-3">
					<span class="text-yellow-500">⭐</span> Featured Projects
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					{featuredProjects.map((project, index) => (
						<div class:list={["group flex flex-col bg-[var(--background-secondary)]/40 border-2 border-[var(--accent)]/30 rounded-3xl overflow-hidden hover:border-[var(--accent)] transition-all duration-300 shadow-lg shadow-[var(--accent)]/5 hover:-translate-y-1 relative", index === 0 ? "md:col-span-2 md:flex-row" : ""]}>
							
							{project.status === 'in-progress' && (
								<div class="absolute top-4 right-4 z-10 px-3 py-1 bg-yellow-500/20 text-yellow-600 dark:text-yellow-400 text-[10px] font-black uppercase tracking-widest rounded-full border border-yellow-500/30 backdrop-blur-md">
									In Progress
								</div>
							)}

							{project.imageUrl && (
								<div class:list={[
									"w-full overflow-hidden border-[var(--border)] relative bg-[var(--background-tertiary)]",
									index === 0 ? "md:w-1/2 aspect-video md:aspect-auto border-b md:border-b-0 md:border-r" : "aspect-video border-b"
								]}>
									<img 
										src={project.imageUrl} 
										alt={project.title} 
										class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
										loading="lazy"
									/>
									<div class="absolute inset-0 bg-gradient-to-t from-[var(--background-secondary)]/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
								</div>
							)}

							<div class:list={["p-8 flex flex-col flex-grow", index === 0 ? "md:w-1/2 justify-center" : ""]}>
								<h3 class="text-2xl font-black leading-tight text-[var(--text-primary)] mb-3 group-hover:text-[var(--accent)] transition-colors flex justify-between items-start">
									{project.title}
								</h3>
								
								<p class="text-[var(--text-secondary)] mb-6 text-sm sm:text-base leading-relaxed line-clamp-3">
									{project.description}
								</p>

								<div class="flex flex-wrap gap-2 mb-8">
									{project.technologies.map(tech => (
										<span class="px-2 py-1 text-[10px] font-bold uppercase tracking-wider bg-[var(--background-tertiary)] text-[var(--text-secondary)] rounded-md border border-[var(--border)] group-hover:border-[var(--accent)]/30 transition-colors">
											{tech}
										</span>
									))}
								</div>
								
								<div class="mt-auto pt-6 border-t border-[var(--border)] flex gap-4">
									{project.githubUrl && (
										<a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2.5 px-4 font-bold text-sm text-[var(--text-primary)] bg-[var(--background-tertiary)] hover:bg-[var(--text-primary)] hover:text-[var(--background)] rounded-xl transition-colors border border-[var(--border)] flex items-center justify-center gap-2">
											<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
											Code
										</a>
									)}
									{project.liveUrl && (
										<a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2.5 px-4 font-bold text-sm text-[var(--background)] bg-[var(--text-primary)] hover:bg-[var(--accent)] rounded-xl transition-colors flex items-center justify-center gap-2">
											Live Demo ↗
										</a>
									)}
								</div>
							</div>
						</div>
					))}
				</div>
			</section>

			<!-- Other Projects -->
			<section>
				<h2 class="text-3xl font-black tracking-tight text-[var(--text-primary)] mb-8">
					More Work
				</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{allProjects.map(project => (
						<div class="group flex flex-col bg-[var(--background-secondary)]/10 border border-[var(--border)] rounded-2xl p-6 hover:border-[var(--text-secondary)] transition-colors relative">
							
							{project.status === 'in-progress' && (
								<div class="absolute -top-3 -right-3 z-10 px-2 py-1 bg-[var(--background)] text-[var(--text-secondary)] text-[9px] font-black uppercase tracking-widest rounded-full border border-[var(--border)]">
									WIP
								</div>
							)}

							{project.imageUrl && (
								<div class="aspect-video w-full overflow-hidden border border-[var(--border)] rounded-xl relative bg-[var(--background-tertiary)] mb-4 shrink-0">
									<img 
										src={project.imageUrl} 
										alt={project.title} 
										class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
										loading="lazy"
									/>
								</div>
							)}

							<h3 class="text-lg font-bold leading-tight text-[var(--text-primary)] mb-2 group-hover:text-[var(--accent)] transition-colors">
								{project.title}
							</h3>
							
							<p class="text-sm text-[var(--text-secondary)] mb-4 line-clamp-2">
								{project.description}
							</p>
							
							<div class="mt-auto pt-4 flex gap-3">
								{project.githubUrl && (
									<a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-bold text-[var(--text-secondary)] hover:text-[var(--text-primary)] transition-colors flex items-center gap-1.5">
										<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
										Code
									</a>
								)}
								{project.liveUrl && (
									<a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-bold text-[var(--accent)] hover:text-purple-500 transition-colors flex items-center gap-1.5">
										Visit ↗
									</a>
								)}
							</div>
						</div>
					))}
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>
